# ══════════════════════════════════════════════════════════════
#  Orqestra — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.2

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=orqestra
POSTGRES_USER=orqestra
POSTGRES_PASSWORD=change_me_in_production

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/app/chroma_db
CHROMA_COLLECTION_NAME=orqestra_docs

# ── Context Budget (tokens per agent) ─────────────────────────
BUDGET_ORCHESTRATOR=4096
BUDGET_DECOMPOSITION=2048
BUDGET_RETRIEVAL=8192
BUDGET_CRITIQUE=4096
BUDGET_SYNTHESIS=8192
BUDGET_META=4096

# ── Tool Config ───────────────────────────────────────────────
WEB_SEARCH_MOCK=true          # set false + add key for real search
WEB_SEARCH_API_KEY=
WEB_SEARCH_TIMEOUT_SECS=5
PYTHON_SANDBOX_TIMEOUT_SECS=10
TOOL_MAX_RETRIES=2

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── App ───────────────────────────────────────────────────────
APP_ENV=development        # development | production
APP_VERSION=0.1.0
SECRET_KEY=change_me_to_a_random_256bit_hex_string
